{
  "mcpServers": {
    "magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ]
    },
    "nano-banana": {
      "command": "npx",
      "args": [
        "-y",
        "@nanana-ai/mcp-server-nano-banana"
      ],
      "env": {
        "NANANA_API_TOKEN": ""
      }
    }
  }
}